/* config/totem-positions.dtsi */

/* left hand top row */
#define LT0 0
#define LT1 1
#define LT2 2
#define LT3 3
#define LT4 4

/* right hand top row */
#define RT0 5
#define RT1 6
#define RT2 7
#define RT3 8
#define RT4 9

/* left hand home row */
#define LM0 10
#define LM1 11
#define LM2 12
#define LM3 13
#define LM4 14

/* right hand home row */
#define RM0 15
#define RM1 16
#define RM2 17
#define RM3 18
#define RM4 19

/* left hand bottom row: include the physical Z key, not the outer extra key */
#define LB0 20
#define LB1 21
#define LB2 22
#define LB3 23
#define LB4 24

/* right hand bottom row: include K M , . / only */
#define RB0 26
#define RB1 27
#define RB2 28
#define RB3 29
#define RB4 30

/* extra outer pinky keys on Totem */
#define EXTL 25
#define EXTR 31

/* thumbs: temporarily keep inner 4 as real urob thumbs,
 * and treat the outer 2 as sacrificial/disabled positions.
 */
#define LH2 32
#define LH1 33
#define LH0 34
#define RH0 35
#define RH1 36
#define RH2 37
